<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify your email</title>
  <style>
    /* Reset styles */
    body, table, td, div, p, a {
      margin: 0;
      padding: 0;
      border: 0;
      font-size: 100%;
      font: inherit;
      vertical-align: baseline;
    }

    body {
      font-family: Arial, sans-serif;
      background-color: #f9fafb;
      color: #374151;
      line-height: 1.6;
      margin: 0;
      padding: 0;
    }

    img {
      border: 0;
      height: auto;
      line-height: 100%;
      outline: none;
      text-decoration: none;
    }

    table {
      border-collapse: collapse;
    }

    td {
      padding: 0;
    }

    .container {
      max-width: 42rem;
      margin: 2rem auto;
      padding: 2rem;
      background-color: #ffffff;
      border-radius: 8px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
      text-align: center;
    }

    .header img {
      height: 3.5rem;
      width: auto;
    }

    .content {
      margin-top: 2rem;
      text-align: center;
      padding: 0 1rem;
    }

    .content h2 {
      color: #374151;
      font-size: 1.5rem;
    }

    .content p {
      margin-top: 0.5rem;
      color: #4b5563;
      line-height: 1.75;
    }

    .otp-box {
      margin: 1.5rem auto;
    }

    .otp-box td {
      width: 3rem;
      height: 3rem;
      font-size: 1.75rem;
      font-weight: bold;
      border: 2px solid #134865;
      border-radius: 8px;
      background: #eef2ff;
      color: #134865;
      text-align: center;
    }

    .footer {
      margin-top: 2rem;
      margin-bottom: 2rem;
      text-align: center;
    }

    .footer p {
      color: #6b7280;
    }

    .footer a {
      color: #134865;
      text-decoration: none;
    }

    .social-media {
      margin-top: 1.5rem;
      text-align: center;
      padding-bottom: 2rem;
    }

    .social-media p {
      color: #6b7280;
      margin-bottom: 0.5rem;
    }

    .social-media a {
      color: #134865;
      text-decoration: none;
      margin: 0 0.5rem;
      font-size: 0.875rem;
      font-weight: bold;
    }

    .social-media a:hover {
      text-decoration: underline;
    }

    @media (max-width: 600px) {
      .social-media a {
        display: block;
        margin: 0.5rem 0;
      }
    }
  </style>
</head>

<body>
  <table width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#f9fafb">
    <tr>
      <td align="center">
        <table class="container" cellpadding="0" cellspacing="0" border="0">
          <!-- Logo -->
          <tr>
            <td class="header">
              <a href="https://neelabh.com.bd">
                <img style="width:100px; height: auto;" src="<%= logo %>" alt="<%= shopName %>" />
              </a>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td class="content">
              <h2>Hi <%= name %>,</h2>
              <p>This is your verification code:</p>

              <!-- OTP Box using Table -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center" class="otp-box">
                <tr>
                  <% for (let i=0; i < 4; i++) { %>
                    <td align="center" valign="middle" >
                      <%= verificationCode[i] %>
                    </td>
                  <% } %>
                </tr>
              </table>

              <p>This code is valid for the next 5 minutes. If the code does not work, you can use this login verification link:</p>

              <p>Thanks, <br /> <%= shopName %> team</p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td class="footer">
              <p>This email was sent to <a href="mailto:<%= contact.email %>"><%= contact.email %></a>. If you'd rather not receive this kind of email, you can <a href="#">unsubscribe</a> or <a href="#">manage your email preferences</a>.</p>
              <p
              style="margin-top: 1rem;"
              >© <%= new Date().getFullYear() %> <%= shopName %>. All Rights Reserved.</p>

              <!-- Social Media Links -->
              <div class="social-media"
              >
                <a href="<%= socialMedia.facebook %>">Facebook</a>
                <a href="<%= socialMedia.twitter %>">Twitter</a>
                <a href="<%= socialMedia.instagram %>">Instagram</a>
                <a href="<%= socialMedia.linkedin %>">LinkedIn</a>
                <a href="<%= socialMedia.youtube %>">YouTube</a>
              </div>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>

</html>
